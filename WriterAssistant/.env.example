# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── Provider: choose "anthropic" or "ollama" ──────────────────────────
PROVIDER=ollama

# ── Option A: Anthropic (requires paid API key) ───────────────────────
# PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Option B: Ollama (free, runs locally — no API key needed) ─────────
# Setup:
#   1. Download and install Ollama from https://ollama.com
#   2. Run: ollama pull llama3.2
#   3. Ollama starts automatically in the background after install
#
# Recommended models (pick one):
#   llama3.2   — 3B params, fast, works on most machines
#   mistral    — 7B params, better quality, needs ~8GB RAM
#   llama3.1   — 8B params, best quality, needs ~8GB RAM
#
OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1   (default, change if using a remote Ollama server)
